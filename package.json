		"autoprefixer": "^10.4.8",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.14.3",
		"svelte-check": "^4.1.1",
		"svelte-exmarkdown": "^5.0.2",
		"tslib": "^2.3.1",
